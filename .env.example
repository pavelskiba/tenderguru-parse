# Скопируйте этот файл в .env для локальной разработки
# и заполните реальными значениями (не коммитьте .env в git).
#
# На Railway эти же переменные задаются в панели проекта:
# Project -> Variables (не в коде и не в git).

TENDERGURU_API_KEY=
TENDERGURU_REFRESH_KEY=

# Каталог для хранения настроек мониторинга, списка отправленных ID и
# журнала запусков (data/settings.json, data/sent-ids.json, data/scheduler-log.json).
# На Railway файловая система эфемерна — чтобы данные не терялись при каждом
# деплое, подключите Railway Volume и укажите его путь монтирования здесь.
DATA_DIR=./data

# Часовой пояс cron-расписания по умолчанию (если не переопределён в настройках на странице).
SCHEDULER_TZ=Europe/Moscow

# --- Email (nodemailer), обязательный канал доставки ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_TO=

# --- Telegram Bot API, обязательный канал доставки ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google Sheets (сервисный аккаунт), опциональный канал доставки ---
# Содержимое JSON-ключа сервисного аккаунта одной строкой (Railway Variables
# поддерживают многострочные значения — можно вставить как есть).
GOOGLE_SERVICE_ACCOUNT_JSON=
SPREADSHEET_ID=
